#!/usr/bin/env bash
# .git-hooks/pre-commit
set -euo pipefail

# Anchor to repo root
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "Running pre-commit checks..."

# 1. Shellcheck for all staged .sh files (safely)
STAGED_SH_FILES=()
while IFS= read -r -d '' staged_file; do
  if [[ "$staged_file" == *.sh ]]; then
    STAGED_SH_FILES+=("$staged_file")
  fi
done < <(git diff --cached --name-only --diff-filter=ACM -z)

if [[ ${#STAGED_SH_FILES[@]} -gt 0 ]]; then
  echo "Running shellcheck on staged files..."
  shellcheck -- "${STAGED_SH_FILES[@]}"
fi

# 2. Run test suite
echo "Running test suite..."
bash tests/run.sh

echo "Pre-commit checks passed!"
